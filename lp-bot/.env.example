# ─────────────────────────────────────────────────
# LP Manager Bot — configuração de ambiente
# Copiar para .env e preencher os valores
# NUNCA commitar o .env em repositório público
# ─────────────────────────────────────────────────

# ── RPC ──────────────────────────────────────────
# Local (hardhat node): http://127.0.0.1:8545
# Arbitrum Mainnet (Alchemy): https://arb-mainnet.g.alchemy.com/v2/SUA_CHAVE
# Arbitrum Sepolia (Alchemy): https://arb-sepolia.g.alchemy.com/v2/SUA_CHAVE
RPC_URL=http://127.0.0.1:8545

# chain ID: 31337=local | 42161=arbitrum | 421614=arb-sepolia
CHAIN_ID=31337

# ── Wallet do keeper ─────────────────────────────
# NUNCA commitar chave real — conta #1 do hardhat (só para testes locais):
PRIVATE_KEY=

# ── Contrato ──────────────────────────────────────
# Endereço do LPKeeper.sol após deploy (cd lp-keeper && npm run deploy)
# IMPORTANTE: este deve ser o endereço do CONTRATO, não de uma wallet
KEEPER_CONTRACT=0x0000000000000000000000000000000000000000

# ── Segurança ─────────────────────────────────────
# true  = simula transações sem enviar (recomendado para primeiros testes)
# false = envia transações reais (gasta gas — use só em produção)
DRY_RUN=true

# ── Logs ──────────────────────────────────────────
# debug | info | warn | error
LOG_LEVEL=info

# ── Mock (desenvolvimento sem API) ────────────────
# true = dados sintéticos | false = APIs reais
USE_MOCK=false
# sideways | trending_up | trending_down | pump | whipsaw | slow_drift
MOCK_SCENARIO=sideways

# ── Telegram (opcional — alertas) ────────────────
# Criar bot em @BotFather e pegar o token
# Pegar CHAT_ID enviando mensagem para @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
